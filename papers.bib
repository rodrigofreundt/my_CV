@inproceedings{freundt2024CCATStatusUpdate,
  keywords = {firstauthor},
  title = {{{CCAT}}: A Status Update on the {{EoR-Spec}} Instrument Module for {{Prime-Cam}}},
  shorttitle = {{{CCAT}}},
  booktitle = {Millimeter, {{Submillimeter}}, and {{Far-Infrared Detectors}} and {{Instrumentation}} for {{Astronomy XII}}},
  author = {Freundt, Rodrigo and Li, Yaqiong and Henke, Doug and Austermann, Jason and Burgoyne, James R. and Chapman, Scott and Choi, Steve K. and Duell, Cody J. and Huber, Zach and Niemack, Michael and Nikola, Thomas and Lin, Lawrence and Riechers, Dominik A. and Stacey, Gordon and Vaskuri, Anna K. and Vavagiakis, Eve M. and Wheeler, Jordan and Zou, Bugao},
  date = {2024-08-16},
  volume = {13102},
  pages = {343--352},
  publisher = {SPIE},
  doi = {10.1117/12.3018477},
  abstract = {The Epoch of Reionization Spectrometer (EoR-Spec) is an upcoming Line Intensity Mapping (LIM) instrument designed to study the evolution of the early universe (z = 3.5 to 8) by probing the redshifted [CII] 158 μm fine-structure line from aggregates of galaxies. The [CII] emission is an excellent tracer of star formation since it is the dominant cooling line from neutral gas heated by OB star light and thus can be used to probe the reionization of the early Universe due to star formation. EoR-Spec will be deployed on Prime-Cam, a modular direct-detection receiver for the 6-meter Fred Young Submillimeter Telescope (FYST), currently under construction by CPI Vertex Antennentechnik GmbH and to be installed near the summit of Cerro Chajnantor in the Atacama Desert. This instrument features an image plane populated with more than 6500 Microwave Kinetic Inductance Detectors (MKIDs) that are illuminated by a 4-lens optical design with a cryogenic, scanning Fabry-Perot Interferometer (FPI) at the pupil of the optical system. The FPI is designed to provide a spectral resolving power of R ∼ 100 over the full spectral range of 210–420 GHz. EoR-Spec will tomographically survey the E-COSMOS and E-CDFS fields with a depth of about 4000 hours over a 5 year period. Here we give an update on EoR-Spec’s final mechanical/optical design and the current status of fabrication, characterization and testing towards first light in 2026.},
  eventtitle = {Millimeter, {{Submillimeter}}, and {{Far-Infrared Detectors}} and {{Instrumentation}} for {{Astronomy XII}}},
  file = {/Users/rodrigofreundt/Zotero/storage/DVQGAQCQ/Freundt et al. - 2024 - CCAT a status update on the EoR-Spec instrument module for Prime-Cam.pdf}
}

@inproceedings{freundt2017DesignLabVIEWbasedPolyphase,
  keywords = {firstauthor},
  title = {Design of a {{LabVIEW-based}} Polyphase Filter Bank Spectrometer for Radio Astronomy Using {{FlexRIO FPGA}} Technology and {{CUDA-enabled GPU}}},
  booktitle = {2017 {{XXXIInd General Assembly}} and {{Scientific Symposium}} of the {{International Union}} of {{Radio Science}} ({{URSI GASS}})},
  author = {Freundt, Rodrigo and Heraud, Jorge A.},
  date = {2017-08},
  pages = {1--4},
  doi = {10.23919/URSIGASS.2017.8105039},
  abstract = {The spectrometer is the most important back-end in single antenna radio astronomy observations. The state-of-the-art designs for this type of instruments propose to reduce the effects of spectral leakage by using the Polyphase Filter Bank (PFB) technique and to achieve wideband and high resolution by using digital, reconfigurable, and high-performance computing hardware, such as commercial-available FPGA and GPU. We herein describe the development of a prototype PFB spectrometer using an integrated hardware and software development environment from National Instruments (Nl), along with FlexRIO FPGA technology for acquisition and CUDA-enabled GPU card for intensive processing. The results show that the proposed design, configured as a 4-tap PFB with 222 channels and 200MHz instantaneous bandwidth, is 95 times faster than a CPU implementation. It can be concluded that the hardware and software design approach used to prototype the spectrometer in this paper must be further studied within radio astronomy applications.},
  eventtitle = {2017 {{XXXIInd General Assembly}} and {{Scientific Symposium}} of the {{International Union}} of {{Radio Science}} ({{URSI GASS}})},
  file = {/Users/rodrigofreundt/Zotero/storage/2LITQCEP/8105039.html}
}

